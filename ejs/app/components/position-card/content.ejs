
    <div class="position-card bg-dark text-secondary rounded-3 shadow-lg gap-2 px-5 py-4 d-flex flex-column align-items-center justify-content-between flex-sm-column flex-md-column flex-lg-row ">

        <div class="d-flex align-items-center gap-5">
                
            <i class="text-primary fs-mid-title fa-solid fa-user"></i>

            <div class="d-flex flex-column gap-1">

                <span class="text-primary fw-bold small text-uppercase"><%= t.components.positionCard.subTitle %></span>

                <h4 class=" fw-bold"><%= t.components.positionCard.title %></h4>

                <span class="text-text fw-semibold"><%= t.components.positionCard.description %></span>

            </div>

        </div>

        <div class="d-flex align-items-center justify-content-center">

            <a href="#" class=" position-btn bg-primary fw-bold px-4 py-3 rounded-2 text-decoration-none text-reset d-flex align-items-center gap-3 text-nowrap">

                <span class="text-dark"><%= t.components.positionCard.btn %></span>

                <i class="fa-solid fa-arrow-right text-dark"></i>

            </a>

        </div>

    </div>

