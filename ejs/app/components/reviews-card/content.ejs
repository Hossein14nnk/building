<div class="card h-100 border-0 shadow-sm review-card-item py-6 px-8">

    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div class="text-warning small">
                <% for (let i = 0; i < reviewsCart.star; i++) { %>
                    <i class="fa-solid fa-star"></i>
                <% } %>
            </div>

            <div class="review-card-quote">
                <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1" x="0px" y="0px" viewBox="0 0 16 20" style="enable-background:new 0 0 16 16;" xml:space="preserve"><g><path d="M4,3C2.343,3,1,4.343,1,6s1.343,3,3,3c0.161,0,0.315-0.023,0.469-0.047C3.782,10.168,2.493,11,1,11v2c3.309,0,6-2.691,6-6   V6C7,4.343,5.657,3,4,3z"/><path d="M12,3c-1.657,0-3,1.343-3,3s1.343,3,3,3c0.161,0,0.315-0.023,0.469-0.047C11.782,10.168,10.493,11,9,11v2   c3.309,0,6-2.691,6-6V6C15,4.343,13.657,3,12,3z"/></g><text x="0" y="31" fill="#000000" font-size="5px" font-weight="bold" font-family="'Helvetica Neue', Helvetica, Arial-Unicode, Arial, Sans-serif">Created by icon 54</text><text x="0" y="36" fill="#000000" font-size="5px" font-weight="bold" font-family="'Helvetica Neue', Helvetica, Arial-Unicode, Arial, Sans-serif">from the Noun Project</text></svg>
            </div>

        </div>

        <p class="fs-big text-text lh-lg mb-0 mb-5 ">
            <%= reviewsCart.comment %>
        </p>

        <div class="d-flex align-items-center border-top pt-4 pb-3">

            <img
                src="<%- getMedia(lang, 'components/comment-profile.jpg', 'images') %>"
                alt="<%= reviewsCart.name %>"
                class="rounded-circle review-card__avatar"
            >

            <div class="ms-3">

                <h6 class="fs-title fw-bold text-title-text mb-0 mb-1">
                    <%= reviewsCart.name %>
                </h6>

                <p class="text-muted small">
                    <%= reviewsCart.position %>
                </p>

                <p class="text-primary fw-bold small">
                    <%= reviewsCart.project %>
                </p>

            </div>

        </div>

    </div>

</div>