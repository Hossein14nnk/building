
    <div class="contact-card text-secondary bg-dark rounded-3 shadow-lg gap-2 px-5 py-3 d-flex flex-column align-items-center justify-content-between flex-sm-column flex-md-column flex-lg-row ">
        
        <div class="col-lg-7 col-10 col-xxl-7 col-xl-7">

            <div class="d-flex align-items-center gap-4">

                <div class=" fs-high-title">
                    <i class="fa-solid fa-headphones text-primary"></i>
                </div>

                <div class="d-flex flex-column gap-1">

                    <h3 class="fw-bold mb-3"><%= t.components.contactCard.question %></h3>

                    <span class="text-text"><%= t.components.contactCard.txt1 %></span>

                    <span class="text-text"><%= t.components.contactCard.txt2 %></span>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-8 col-xxl-3 col-xl-3 border rounded-2 p-4 d-flex align-items-center gap-3">

            <i class="fa-solid fa-phone-volume fs-mid-title  text-primary"></i>

            <div class="d-flex flex-column ">

                <span class="fw-semibold"><%= t.components.contactCard.call %></span>

                <span class=" fs-3 fw-bold text-nowrap text-primary"><%= t.components.contactCard.number %></span>

            </div>

        </div>

    </div>
