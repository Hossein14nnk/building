<div class="pricing-table default-style d-flex flex-column align-items-center gap-4 rounded-1 shadow px-6 py-5">
    <h4 class="fs-mid-title fw-semibold"><%- defaultStyle.title %></h4>
    <span class="fs-big"><%- defaultStyle.subtitle %></span>
    <span class="fs-big"><span class="fs-mid-title fw-bold"><%- defaultStyle.price %></span><%- defaultStyle.priceText %></span>
    <i class="fa-solid fa-house fs-mid-title icon"></i>
    <div class="d-flex flex-column align-items-start gap-4 w-100">
        <div class="d-flex flex-row align-items-center gap-3">
            <i class="fa-solid fa-check"></i>
            <span class="fs-big fw-semibold"><%- defaultStyle.itemOneText %></span>
        </div>
        <div class="d-flex flex-row align-items-center gap-3">
            <i class="fa-solid fa-check"></i>
            <span class="fs-big fw-semibold"><%- defaultStyle.itemTwoText %></span>
        </div>
        <div class="d-flex flex-row align-items-center gap-3">
            <i class="fa-solid fa-check"></i>
            <span class="fs-big fw-semibold"><%- defaultStyle.itemThreeText %></span>
        </div>
        <div class="d-flex flex-row align-items-center gap-3">
            <i class="fa-solid fa-check"></i>
            <span class="fs-big fw-semibold"><%- defaultStyle.itemFourText %></span>
        </div>
        <div class="d-flex flex-row align-items-center gap-3">
            <i class="fa-solid fa-check"></i>
            <span class="fs-big fw-semibold"><%- defaultStyle.itemFiveText %></span>
        </div>
    </div>
    <a href=""
        class="border border-black text-decoration-none text-black w-100 d-flex align-items-center justify-content-center py-2 fs-big fw-bold rounded-1"><%- defaultStyle.btnText %></a>
</div>