<div class="need-help-card d-flex flex-column align-items-start gap-3 px-5 py-7 rounded-1 shadow">
    <h3 class="fs-mid-title fw-bold"><%- needHelpCard.title %></h3>
    <span class="fs-title"><%- needHelpCard.subtitle %></span>
    <div class="d-flex flex-column w-100 gap-5 mt-3">
        <div class="d-flex flex-row align-items-center gap-4">
            <i class="fa-solid fa-phone"></i>
            <span class="fw-semibold"><%- needHelpCard.itemOne %></span>
        </div>
        <div class="d-flex flex-row align-items-center gap-4">
            <i class="fa-solid fa-inbox"></i>
            <span class="fw-semibold"><%- needHelpCard.itemTwo %></span>
        </div>
        <div class="d-flex flex-row align-items-center gap-4">
            <i class="fa-solid fa-clock"></i>
            <span class="fw-semibold"><%- needHelpCard.itemThree %></span>
        </div>
    </div>
</div>