<div class="card h-100 border-0 shadow-sm review-card__item">

    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div class="text-warning fs-6">
                ★★★★★
            </div>

            <div class="review-card__quote">
                <i class="bi bi-quote"></i>
            </div>

        </div>

        <p class="review-card__text mb-5">
            <%= reviewsCart.comment %>
        </p>

        <div class="d-flex align-items-center border-top pt-4">

            <img
                src="<%- getMedia(lang, 'components/comment-profile.jpg', 'images') %>"
                alt="<%= reviewsCart.name %>"
                class="rounded-circle review-card__avatar"
            >

            <div class="ms-3">

                <h6 class="fw-bold mb-1">
                    <%= reviewsCart.name %>
                </h6>

                <div class="text-muted small">
                    <%= reviewsCart.position %>
                </div>

                <div class="review-card__project">
                    <%= reviewsCart.project %>
                </div>

            </div>

        </div>

    </div>

</div>