


    <div class="quote-card text-secondary bg-dark rounded-3 shadow-lg gap-2 px-5 py-3 d-flex flex-column align-items-center justify-content-between flex-sm-column flex-md-column flex-lg-row ">

        <div class="d-flex align-items-center gap-5">
                
            <i class=" fa-solid fa-city text-primary fs-mid-title"></i>

            <div class="d-flex flex-column gap-1">

                <p class="fw-bold small text-uppercase text-primary"><%= t.components.quoteCode.subTitle %></p>

                <h4 class="fw-bold"><%= t.components.quoteCode.title %></h4>

                <p class="text-text fw-semibold"><%= t.components.quoteCode.description %></p>

            </div>

        </div>

        <div class="d-flex align-items-center justify-content-center">

            <a href="#" class="quote-btn bg-primary fw-bold px-4 py-3 rounded-2 text-decoration-none text-reset d-flex align-items-center gap-3 text-nowrap">

                <span class="text-dark"><%= t.components.quoteCode.btn %></span>

                <i class="fa-solid fa-arrow-right text-dark"></i>

            </a>

        </div>

    </div>
