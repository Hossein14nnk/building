<%- include('../layouts/page/head.ejs' , {title: "register", addCount: 0}); -%>

    <main class="d-flex flex-column" id="register">


    <section class="register container py-8 ">
        
        <div class="d-flex j flex-column flex-xxl-row flex-xl-row flex-lg-row gap-20">

            <div class="col-9 col-xxl-5 col-xl-5 col-lg-6 align-self-center d-flex">

                <div class="card bg-light rounded-4 shadow-sm p-5 d-flex flex-column gap-4">

                    <span class="text-primary fw-bold text-uppercase small"><%- t.pages.register.subtitle %></span>

                    <h1 class="fw-bold display-5"><%- t.pages.register.title %></h1>

                    <p class="text-muted"><%- t.pages.register.description %></p>


                    <form class="d-flex flex-column gap-4">

                        <div class="">
                            <label for="name" class="fw-semibold">
                                <%- t.pages.register.firstname %> <span class="text-danger">*</span>
                            </label>

                            <div class="rounded-2 border px-2 d-flex align-items-center justify-content-between">
                                <input id="name" type="text" class=" py-3" placeholder="<%- t.pages.register.placeHolderFirst %>">
                                    <span class="">
                                        <i class="fa-solid fa-user text-text"></i>
                                    </span>
                            </div>
                        </div>

                        <div class="">
                            <label for="family" class=" fw-semibold">
                                <%- t.pages.register.lastname %> <span class="text-danger">*</span>
                            </label>

                            <div class="rounded-2 border px-2 d-flex align-items-center justify-content-between">
                                <input id="family" type="text" class=" py-3" placeholder="<%- t.pages.register.placeHolderLastname %>">

                                    <i class="fa-solid fa-user text-text"></i>
                            </div>
                        </div>

                        <div class="">
                            <label for="email" class=" fw-semibold">
                                <%- t.pages.register.email %> <span class="text-danger">*</span>
                            </label>

                            <div class="rounded-2 border px-2 d-flex align-items-center justify-content-between">
                                <input id="email" type="email" class=" py-3" placeholder="<%- t.pages.register.placeHolderemail %>">

                                    <i class="fa-solid fa-envelope text-text"></i>
                            </div>
                        </div>

                        <div class="">
                            <label for="phone" class=" fw-semibold">
                                <%- t.pages.register.phone %>
                            </label>

                            <div class="rounded-2 border px-2 d-flex align-items-center justify-content-between">
                                <input id="phone" type="text" class=" py-3" placeholder="<%- t.pages.register.placeHolderphone %>">

                                    <i class="fa-solid fa-light fa-phone text-text"></i>
                            </div>
                        </div>

                        <div class="">
                            <label for="password" class=" fw-semibold">
                                <%- t.pages.register.password %> <span class="text-danger">*</span>
                            </label>

                            <div class="rounded-2 border px-2 d-flex align-items-center justify-content-between">
                                <input id="password" type="password" class=" py-3 " placeholder="<%- t.pages.register.placeHolderPassword %>">

                                <div class="d-flex align-items-center gap-4">
                                    <i class="fa-solid fa-lock text-text"></i>

                                    <i class="fa-solid fa-eye text-text"></i>
                                </div>
                                    
                            </div>
                        </div>

                        <div class="">
                            <label for="password2" class=" fw-semibold">
                               <%- t.pages.register.confirm %> <span class="text-danger">*</span>
                            </label>

                            <div class="rounded-2 border px-2 d-flex align-items-center justify-content-between">
                                <input id="password2" type="password" class=" py-3" placeholder="<%- t.pages.register.placeHolderconfirm %>">

                                 <div class="d-flex align-items-center gap-4">
                                    <i class="fa-solid fa-lock text-text"></i>

                                    <i class="fa-solid fa-eye text-text"></i>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 align-items-center">
                           <input class="form-check-input p-2 border rounded" type="checkbox" id="check">

                            <label for="check" class="" >
                                <%- t.pages.register.privacy1 %>
                                <a href="#" class="text-warning text-decoration-none">
                                    <%- t.pages.register.privacy2 %>
                                </a>
                                <%- t.pages.register.privacy3 %>
                                <a href="#" class="text-warning text-decoration-none">
                                    <%- t.pages.register.privacy4 %>
                                </a>
                            </label>

                        </div>

                        <button class="check-button bg-primary mt-2 w-100 py-3 fw-bold text-uppercase rounded-2 d-flex gap-5 justify-content-center align-items-center">
                            <span class=""><%- t.pages.register.btnRegister %></span>
                            <i class="fa-solid fa-arrow-right"></i>
                        </button>

                        <div class="d-flex align-items-center ">
                            <hr class="flex-grow-1 bg-dark">
                            <span class="mx-3 text-muted fs-small"><%- t.pages.register.or %></span>
                            <hr class="flex-grow-1 bg-dark">
                        </div>

                        <button class="w-100 py-3 border rounded-2 fw-bold">
                           <i class="fa-brands fa-google text-primary fs-mid-title"></i>
                            <%- t.pages.register.btnGoogle %>
                        </button>

                        <button class="w-100 py-3 border rounded-2 fw-bold">
                            <i class="fa-brands fa-linkedin text-primary fs-mid-title"></i>
                            <%- t.pages.register.btnLinkedin %>
                        </button>

                        <p class="text-center">
                            <%- t.pages.register.question %>
                            <a href="#" class="text-primary text-decoration-none fw-semibold">
                                <%- t.pages.register.signIn %>
                            </a>
                        </p>

                    </form>

                </div>
            </div>

            <aside class="col-6 col-xxl-4 col-xl-5 col-lg-5 py-10">

               <%- include('../components/account-features/content.ejs', {accountFeatures: t.components.accountFeatures}); -%>

            </aside>

        </div>
    </section>

    </main>

    <%- include('../components/footer/content.ejs', {accountFeatures: t.components.accountFeatures}); -%>

    <script src="./assets/js/mizchin.min.js"></script>
</body>

</html>