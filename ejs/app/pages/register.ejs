<!DOCTYPE html>
<html dir="<%= t.direction %>" lang="<%= t.language %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>pages</title>
    <link rel="icon" type="image/png" href="<%= getMedia(lang, 'single/logo-web3.webp', 'images') %>">
    <base href="<%= basePathPages() %>">
    <link rel="stylesheet" href="./assets/icons/fontawesome/css/all.min.css">
    <link rel="stylesheet" href="./assets/vendors/bootstrap/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="./assets/css/components.min.css">
    <link rel="stylesheet" href="./assets/css/style.min.css">
</head>

<body class="font-primary">

    <main class="d-flex flex-column" id="register">


    <section class="register container py-8 ">
        
        <div class="d-flex j flex-column flex-xxl-row flex-xl-row flex-lg-row gap-20">

            <div class="col-9 col-xxl-5 col-xl-5 col-lg-6 align-self-center d-flex">

                <div class="card bg-light rounded-4 shadow-sm p-5 d-flex flex-column gap-4">

                    <span class="text-primary fw-bold text-uppercase small">Create Account</span>

                    <h1 class="fw-bold display-5">Register</h1>

                    <p class="text-muted">Join Buildex Construction and get started today.</p>


                    <form class="d-flex flex-column gap-4">

                        <div class="">
                            <label for="name" class="fw-semibold">
                                First Name <span class="text-danger">*</span>
                            </label>

                            <div class="rounded-2 border px-2 d-flex align-items-center justify-content-between">
                                <input id="name" type="text" class=" py-3" placeholder="Enter your first name">
                                    <span class="">
                                        <i class="fa-solid fa-user text-text"></i>
                                    </span>
                            </div>
                        </div>

                        <div class="">
                            <label for="family" class=" fw-semibold">
                                Last Name <span class="text-danger">*</span>
                            </label>

                            <div class="rounded-2 border px-2 d-flex align-items-center justify-content-between">
                                <input id="family" type="text" class=" py-3" placeholder="Enter your last name">

                                    <i class="fa-solid fa-user text-text"></i>
                            </div>
                        </div>

                        <div class="">
                            <label for="email" class=" fw-semibold">
                                Email Address <span class="text-danger">*</span>
                            </label>

                            <div class="rounded-2 border px-2 d-flex align-items-center justify-content-between">
                                <input id="email" type="email" class=" py-3" placeholder="Enter your email address">

                                    <i class="fa-solid fa-envelope text-text"></i>
                            </div>
                        </div>

                        <div class="">
                            <label for="phone" class=" fw-semibold">
                                Phone Number
                            </label>

                            <div class="rounded-2 border px-2 d-flex align-items-center justify-content-between">
                                <input id="phone" type="text" class=" py-3" placeholder="Enter your phone number">

                                    <i class="fa-solid fa-light fa-phone text-text"></i>
                            </div>
                        </div>

                        <div class="">
                            <label for="password" class=" fw-semibold">
                                Password <span class="text-danger">*</span>
                            </label>

                            <div class="rounded-2 border px-2 d-flex align-items-center justify-content-between">
                                <input id="password" type="password" class=" py-3 " placeholder="Create a password">

                                <div class="d-flex align-items-center gap-4">
                                    <i class="fa-solid fa-lock text-text"></i>

                                    <i class="fa-solid fa-eye text-text"></i>
                                </div>
                                    
                            </div>
                        </div>

                        <div class="">
                            <label for="password2" class=" fw-semibold">
                                Confirm Password <span class="text-danger">*</span>
                            </label>

                            <div class="rounded-2 border px-2 d-flex align-items-center justify-content-between">
                                <input id="password2" type="password" class=" py-3" placeholder="Confirm your password">

                                 <div class="d-flex align-items-center gap-4">
                                    <i class="fa-solid fa-lock text-text"></i>

                                    <i class="fa-solid fa-eye text-text"></i>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 align-items-center">
                           <input class="form-check-input p-2 border rounded" type="checkbox" id="check">

                            <label for="check" class="" >
                                I agree to the
                                <a href="#" class="text-warning text-decoration-none">
                                    Terms & Conditions
                                </a>
                                and
                                <a href="#" class="text-warning text-decoration-none">
                                    Privacy Policy
                                </a>
                            </label>

                        </div>

                        <button class="check-button bg-primary mt-2 w-100 py-3 fw-bold text-uppercase rounded-2 d-flex gap-5 justify-content-center align-items-center">
                            <span class="">Register Now</span>
                            <i class="fa-solid fa-arrow-right"></i>
                        </button>

                        <div class="d-flex align-items-center ">
                            <hr class="flex-grow-1 bg-dark">
                            <span class="mx-3 text-muted fs-small">OR</span>
                            <hr class="flex-grow-1 bg-dark">
                        </div>

                        <button class="w-100 py-3 border rounded-2 fw-bold">
                           <i class="fa-brands fa-google text-primary fs-mid-title"></i>
                            Continue with Google
                        </button>

                        <button class="w-100 py-3 border rounded-2 fw-bold">
                            <i class="fa-brands fa-linkedin text-primary fs-mid-title"></i>
                            Continue with LinkedIn
                        </button>

                        <p class="text-center">
                            Already have an account?
                            <a href="#" class="text-primary text-decoration-none fw-semibold">
                                Sign In
                            </a>
                        </p>

                    </form>

                </div>
            </div>

            <aside class="col-6 col-xxl-4 col-xl-5 col-lg-5 py-10">

               <%- include('../components/account-features/content.ejs', {accountFeatures: t.components.accountFeatures}); -%>

            </aside>

        </div>
    </section>

    </main>

    <%- include('../components/footer/content.ejs', {accountFeatures: t.components.accountFeatures}); -%>

    <script src="./assets/js/mizchin.min.js"></script>
</body>

</html>