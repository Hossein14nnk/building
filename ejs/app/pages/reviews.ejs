                        </a>
                    </li>

                    <li class="px-1 px-xxl-5 px-xl-5 px-lg-5 px-md-5 px-sm-2 py-2 d-flex align-items-center fw-bold">
                        <a class="text-dark" href="#">
                            <%- t.pages.Reviews.filter3 %>
                        </a>
                    </li>

                    <li class="px-1 px-xxl-5 px-xl-5 px-lg-5 px-md-5 px-sm-2 py-2 d-flex align-items-center fw-bold">
                        <a class="text-dark" href="#">
                            <%- t.pages.Reviews.filter4 %>
                        </a>
                    </li>
                </ul>

            </div>


            <div class="row align-items-stretch justify-content-center row-gap-6">
                <div class="col-12 col-lg-4 col-md-6">
                    <%- include('../components/reviews-card/content.ejs', {reviewsCart: t.components.reviewsCart}); -%>
                </div>
                <div class="col-12 col-lg-4 col-md-6">
                    <%- include('../components/reviews-card/content.ejs', {reviewsCart: t.components.reviewsCart}); -%>
                </div>
                <div class="col-12 col-lg-4 col-md-6">
                    <%- include('../components/reviews-card/content.ejs', {reviewsCart: t.components.reviewsCart}); -%>
                </div>
                <div class="col-12 col-lg-4 col-md-6">
                    <%- include('../components/reviews-card/content.ejs', {reviewsCart: t.components.reviewsCart}); -%>
                </div>
                <div class="col-12 col-lg-4 col-md-6">
                    <%- include('../components/reviews-card/content.ejs', {reviewsCart: t.components.reviewsCart}); -%>
                </div>
                <div class="col-12 col-lg-4 col-md-6">
                    <%- include('../components/reviews-card/content.ejs', {reviewsCart: t.components.reviewsCart}); -%>
                </div>
            </div> 

        </section>
 
        <section class="project-cta py-0 text-light">
            <div class="container py-8 px-20">
                <div class="d-flex align-items-center justify-content-between flex-column flex-xxl-row  flex-xl-row gap-4">

                    <div class="d-flex flex-column gap-4">

                        <h4 class="fw-bold fs-high-title"><%- t.pages.Reviews.sectionEndtitle %></h4>

                        <p class="text-text">
                           <%- t.pages.Reviews.sectionEndDescription %>
                        </p>
                    </div>

