<%- include('../layouts/page/head.ejs' , {title: "Reviews", addCount: 0}); -%>
    <%- include('../components/header/content.ejs', ); -%>
    <main class="d-flex flex-column pt-20" id="Reviews">

        <section class="hero py-20 text-secondary-text d-flex justify-content-start">
            <div class="container d-flex ">
                <div class="d-flex flex-column gap-4 col-10 col-xxl-5 col-xl-6 col-lg-8 align-items-start">
                    <div class="small ">
                        <a href="#"><%- t.pages.Reviews.breadcromp1 %></a>
                        <span class="mx-2">›</span>

                        <a href="#"><%- t.pages.Reviews.breadcromp2 %></a>
                        <span class="mx-2">›</span>
                        <span><%- t.pages.Reviews.breadcromp3 %></span>
                    </div>
                    <span class="text-primary fw-bold text-uppercase border-secondary border-start px-3 border-3 lh-1"><%- t.pages.Reviews.heroSubTitle %></span>

                    <h1 class="fs-big-title fw-bold">
                       <%- t.pages.Reviews.heroTitle1 %> <br>
                        <span class="text-primary"><%- t.pages.Reviews.heroTitle2 %></span>
                    </h1>

                    <p class="text-secondary fs-mid-title">
                        <%- t.pages.Reviews.heroDescription %>
                    </p>
                </div>
            </div>
        </section>

        <section class="wrapper-items">
            <div class="container">
                <%- include('../components/items-card/content.ejs'); -%>
