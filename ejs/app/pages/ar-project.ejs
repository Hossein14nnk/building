                        <span class="number rounded-1 bg-white">2</span>
                        <span class="number rounded-1 bg-white">3</span>
                        <span class="number rounded-1 bg-white">...</span>
                        <span class="number rounded-1 bg-white">8</span>
                        <a href="">
                            <i class="fa-light fa-arrow-right fs-normal p-2 bg-primary rounded-1 bg-white"></i>
                        </a>
                    </div>
                </div>
            </div>
