        <section class="process-section py-7">
            <div class="container">
                <div class="row align-items-start gy-5">
                    <aside class="col-lg-4">
                        <span class="fs-big fw-bold text-primary text-uppercase">
                            <%- t.pages.arProject.sectiontreeSubtitle %>
                        </span>
                        <h2 class="fs-high-title fw-bold mt-3 mb-0">
                           <%- t.pages.arProject.sectiontreetitle %>
                        </h2>
                        <span class="section-divider d-block mt-4"></span>
                        <p class="fs-normal text-text mt-4 mb-5">
                          <%- t.pages.arProject.sectiontreedescription %>
                        </p>
                        <a id="btnCTA"
                            class="bg-primary text-black d-flex align-items-center gap-4 rounded-1 btn-hover fw-bold"
                            href="#">
                            <span class="fs-normal"><%- t.pages.arProject.sectiontreebtn %></span>
                            <i class="fas fa-arrow-right-long fs-small"></i>
                        </a>

                    </aside>

                    <div class="col-lg-8">
                       
                        <%- include('../components/second-feature-cards/content.ejs', {secondFeatureCards: t.components.secondFeatureCards}); -%>
                    </div>

                </div>

            </div>

        </section>
        <section class="container-fluid">
            <div class="container">
                <%- include('../components/quote-card/content.ejs', {quoteCode: t.components.quoteCode}); -%>
            </div>
        </section>

    </main>


    <%- include('../components/footer/content.ejs', {accountFeatures: t.components.accountFeatures}); -%>

    <script src="./assets/js/mizchin.min.js"></script>
</body>

</html>