<%- include('../layouts/page/head.ejs' , {title: "ar-project", addCount: 0}); -%>

    <%- include('../components/header/content.ejs', ); -%>
    <main class="d-flex flex-column" id="ar-project">

        <section id="" class="conainer-fluid bg-on-secondary d-flex align-items-center">
            <div class="container d-flex gap-4 flex-column">
                <span class="text-primary fw-bold fs-normal"><%- t.pages.arProject.heroSubtitle %></span>
                <h1 class="text-light fw-bold fs-big-title"><%- t.pages.arProject.heroTitle1 %>
                    <br><span class="text-primary"><%- t.pages.arProject.heroTitle2 %></span>
                </h1>
                <p class="text-text fw-medium fs-title"><%- t.pages.arProject.heroDescription %></p>
            </div>
        </section>
        <section class="container-fluid">
            <div class="container">
                <div class="d-flex align-items-center justify-content-between w-100 mb-5">
                    <ul class="d-flex align-items-center fw-semibold fs-small">
                        <li class="px-1 px-xxl-5 px-xl-5 px-lg-5 px-md-5 bg-primary rounded-1 px-sm-2 py-2 d-flex align-items-center">
                            <a class="fs-normal active" href="#">
                                 <%- t.pages.arProject.filter1 %>
                            </a>
                        </li>

                        <li class="px-1 px-xxl-5 px-xl-5 px-lg-5 px-md-5 px-sm-2 py-2 d-flex align-items-center">
                            <a class="fs-normal" href="#">
                                  <%- t.pages.arProject.filter2 %>
                            </a>
                        </li>

                        <li class="px-1 px-xxl-5 px-xl-5 px-lg-5 px-md-5 px-sm-2 py-2 d-flex align-items-center">
                            <a class="fs-normal" href="#">
                                <%- t.pages.arProject.filter3 %>
                            </a>
                        </li>

                        <li class="px-1 px-xxl-5 px-xl-5 px-lg-5 px-md-5 px-sm-2 py-2 d-flex align-items-center">
                            <a class="fs-normal" href="#">
                                  <%- t.pages.arProject.filter4 %>
                            </a>
                        </li>

                        <li class="px-1 px-xxl-5 px-xl-5 px-lg-5 px-md-5 px-sm-2 py-2 d-flex align-items-center">
                            <a class="fs-normal" href="#">
                                 <%- t.pages.arProject.filter5 %>
                            </a>
                        </li>

                    </ul>
                    <select class="form-select w-auto rounded-0 border rounded-1 px-4 py-1 fs-normal">
                        <option><%- t.pages.arProject.option1 %></option>
                        <option><%- t.pages.arProject.option2 %></option>
                        <option> <%- t.pages.arProject.option3 %></option>
                    </select>
                </div>
                <div class="col-xl-12 g-2">
                    <div class="row g-4">
                        <div class="col-md-6 col-xl-4 d-flex">
                            <%- include('../components/project-card/content.ejs', {projectCard: t.components.projectCard}); -%>
            
                        </div>
                        <div class="col-md-6 col-xl-4 d-flex">
                            <%- include('../components/project-card/content.ejs', {projectCard: t.components.projectCard}); -%>
                        </div>
                        <div class="col-md-6 col-xl-4 d-flex">
                            <%- include('../components/project-card/content.ejs', {projectCard: t.components.projectCard}); -%>
                        </div>
                        <div class="col-md-6 col-xl-4 d-flex">
                           <%- include('../components/project-card/content.ejs', {projectCard: t.components.projectCard}); -%>
                        </div>
                        <div class="col-md-6 col-xl-4 d-flex">
                            <%- include('../components/project-card/content.ejs', {projectCard: t.components.projectCard}); -%>
                        </div>
                        <div class="col-md-6 col-xl-4 d-flex">
                           <%- include('../components/project-card/content.ejs', {projectCard: t.components.projectCard}); -%>
                        </div>
