                            <%- t.pages.gallery.filter1 %>
                        </a>
                    </li>

                    <li class="px-1 px-xxl-5 px-xl-5 px-lg-5 px-md-5 px-sm-2 py-2 d-flex align-items-center">
                        <a class="" href="#">
                            <%- t.pages.gallery.filter2 %>
                        </a>
                    </li>

                    <li class="px-1 px-xxl-5 px-xl-5 px-lg-5 px-md-5 px-sm-2 py-2 d-flex align-items-center">
