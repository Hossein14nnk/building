                        <a class="" href="#">
                            <%- t.pages.gallery.filter6 %>
                        </a>
                    </li>
                </ul>


                    <select class="form-select sort-select text-lg-end d-flex gap-6 align-items-center border rounded px-4 py-1 fs-small">
                        <option class="">Latest Firs</option>
                        <option class="">Oldest First</option>
                        <option class="">Oldest First</option>
                    </select>


            </div>


            <div class="row align-items-stretch justify-content-center">
