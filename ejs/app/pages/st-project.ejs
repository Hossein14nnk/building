                        </div>
                        <div class="col-12 col-xxl-6 col-xl-6 col-lg-6">
                            <%- include('../components/services-overview/content.ejs', {servicesOverview: t.components.servicesOverview}); -%>
                        </div>

                    </div>
                </section>
                <section class="process py-8 d-flex flex-column gap-4">
                    <h2 class="fw-bold"><%- t.pages.stProject.sectiontreetitle %></h2>
                    <hr>
                    <div class="project-gallery gap-2 d-grid"> 
                        <img src="<%= getMedia(lang, 'services/ChatGPT Image Jul 12, 2026, 03_39_32 AM.png', 'images'); %>" class="img-fluid rounded-3 shadow-sm " alt="">
                        <img src="<%= getMedia(lang, 'services/ChatGPT Image Jul 12, 2026, 03_39_32 AM.png', 'images'); %>" class="img-fluid rounded-3 shadow-sm " alt="">
                        <img src="<%= getMedia(lang, 'services/ChatGPT Image Jul 12, 2026, 03_39_32 AM.png', 'images'); %>" class="img-fluid rounded-3 shadow-sm " alt="">
                        <img src="<%= getMedia(lang, 'services/ChatGPT Image Jul 12, 2026, 03_39_32 AM.png', 'images'); %>" class="img-fluid rounded-3 shadow-sm " alt="">
                        <img src="<%= getMedia(lang, 'services/ChatGPT Image Jul 12, 2026, 03_39_32 AM.png', 'images'); %>" class="img-fluid rounded-3 shadow-sm " alt="">
                        <img src="<%= getMedia(lang, 'services/ChatGPT Image Jul 12, 2026, 03_39_32 AM.png', 'images'); %>" class="img-fluid rounded-3 shadow-sm " alt="">
                    </div>
                </section>
            </div>

            <aside class="col-11 col-xxl-3 col-xl-3 col-lg-4 col-md-5 py-8 d-flex flex-column justify-content-between align-self-center gap-4">
                <div>
                    <%- include('../components/project-overview/content.ejs', {projectOverview: t.components.projectOverview}); -%>
                </div>
                <div>
                    <%- include('../components/icon-banner-CTA/content.ejs', {iconBannerCTA: t.components.iconBannerCTA}); -%> 
                </div>

                <div class="card-body px-4 py-8 order-0 shadow-sm rounded-3 d-flex flex-column gap-8">

                    <h4 class="fw-bold"><%- t.pages.stProject.insidetitle %></h4>

                    <div class="border-bottom border-primary border-3" style="width:50px"></div>

                    <ul class="list-group d-flex flex-column gap-2">

                        <%- include('../components/project-list/content.ejs', {projectList: t.components.projectList}); -%>
                        <%- include('../components/project-list/content.ejs', {projectList: t.components.projectList}); -%>
                        <%- include('../components/project-list/content.ejs', {projectList: t.components.projectList}); -%>
                        <%- include('../components/project-list/content.ejs', {projectList: t.components.projectList}); -%>


                    </ul>

                </div>

               
                <div class="overflow-hidden rounded">
                    <%- include('../components/process-timeline/content.ejs', {processTimeline: t.components.processTimeline}); -%>
                </div>
            </aside> 

        </div>

    </main>

    <%- include('../components/footer/content.ejs', {accountFeatures: t.components.accountFeatures}); -%>

    
    <script src="./assets/js/mizchin.min.js"></script>
</body>

</html>