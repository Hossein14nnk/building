<!DOCTYPE html>
<html dir="<%= t.direction %>" lang="<%= t.language %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>pages</title>
    <link rel="icon" type="image/png" href="<%= getMedia(lang, 'single/logo-web3.webp', 'images') %>">
    <base href="<%= basePathPages() %>">
    <link rel="stylesheet" href="./assets/icons/fontawesome/css/all.min.css">
    <link rel="stylesheet" href="./assets/vendors/bootstrap/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="./assets/css/components.min.css">
    <link rel="stylesheet" href="./assets/css/style.min.css">
</head>

<body class="font-primary">

    <main class="d-flex flex-column" id="services">


        <!-- Hero -->
        <section class="bg-black text-white py-5 position-relative overflow-hidden">

            <div class="container py-4">

                <!-- Breadcrumb -->
                <nav class="small mb-5">
                    <a href="#" class="text-decoration-none text-white">Home</a>

                    <span class="mx-2 text-secondary">&gt;</span>

                    <a href="#" class="text-decoration-none text-white">Services</a>

                    <span class="mx-2 text-secondary">&gt;</span>

                    <span class="text-secondary">
                        Construction Management
                    </span>
                </nav>

                <div class="row">

                    <div class="col-lg-6">

                        <span class="text-warning fw-bold text-uppercase">
                            Our Service
                        </span>

                        <h1 class="display-3 fw-bold mt-3 mb-4">

                            Construction

                            <br>

                            <span class="text-warning">
                                Management
                            </span>

                        </h1>

                        <div class="bg-warning mb-4"
                            style="width:60px;height:3px;"></div>

                        <p class="text-secondary fs-5 lh-lg">
                            We oversee every phase of construction to ensure your
                            project is delivered on time, on budget,
                            and to the highest quality standards.
                        </p>

                    </div>

                </div>

            </div>

        </section>

        <!-- Content -->
        <section class="py-5">

            <div class="container">

                <div class="row justify-content-center">

                    <div class="col-lg-10">

                        <!-- Image -->

                        <img src="images/service.jpg"
                            class="img-fluid rounded-3 shadow-sm mb-5"
                            alt="">

                        <!-- Overview -->

                        <h2 class="fw-bold mb-4">
                            Overview
                        </h2>

                        <p class="text-secondary lh-lg">

                            Our construction management services provide
                            comprehensive oversight of your project from planning to
                            completion. We coordinate all aspects of construction,
                            including budgeting, scheduling, resource allocation,
                            and quality control, to ensure seamless execution and
                            successful outcomes.

                        </p>

                        <p class="text-secondary lh-lg">

                            With a focus on safety, efficiency, and transparent
                            communication, we act as your trusted partner every step
                            of the way.

                        </p>

                    </div>

                </div>

            </div>

        </section>


    </main>

    <%- include('../components/footer/content.ejs', {accountFeatures: t.components.accountFeatures}); -%>

    
    <script src="./assets/js/mizchin.min.js"></script>
</body>

</html>