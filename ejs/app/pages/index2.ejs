<!DOCTYPE html>
<html dir="<%= t.direction %>" lang="<%= t.language %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>pages</title>
    <link rel="icon" type="image/png" href="<%= getMedia(lang, 'single/logo-web3.webp', 'images') %>">
    <base href="<%= basePathPages() %>">
    <link rel="stylesheet" href="./assets/icons/fontawesome/css/all.min.css">
    <link rel="stylesheet" href="./assets/vendors/bootstrap/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="./assets/css/components.min.css">
    <link rel="stylesheet" href="./assets/css/style.min.css">
</head>

<body class="font-primary">

    <main class="d-flex flex-column" id="second-demo">

    <section class="hero text-white pb-0 d-flex flex-column w-100 gap-20 overflow-hidden">

        <div class="container d-flex flex-column">
            <div class="d-flex gap-4 justify-content-between align-items-center">

                <div class="d-flex flex-column gap-2">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary me-3 rounded-4" style="width:30px;height:3px;"></div>
                        <span class="text-uppercase text-light">Premium Construction Services</span>
                    </div>

                    <h1 class="fw-bold text-uppercase d-flex flex-column fs-mega-title">
                        We Build 
                        Stronger Futures
                        <span class="text-primary">Together</span>
                    </h1>

                    <p class="text-secondary my-4 fw-semibold">
                        We deliver innovative construction solutions with
                        quality, integrity and excellence.
                    </p>

                    <div class="d-flex gap-3 mt-4 align-items-center">

                        <a href="#" class="service px-4 py-2 fw-semibold rounded-1 bg-primary text-dark fs-big d-flex justify-content-center align-items-center gap-2 border-primary border">
                            OUR SERVICES
                            <i class="fa-solid fa-arrow-right"></i>
                        </a>

                        <a href="#" class="view px-4 py-2 fw-semibold rounded-1 fs-big d-flex justify-content-center align-items-center border-primary border gap-2">
                            VIEW PROJECTS
                            <i class="fa-solid fa-arrow-right text-primary"></i>
                        </a>

                    </div>

                </div>


                <div class="justify-content-end d-none d-xxl-flex d-xl-flex d-lg-flex d-md-flex">

                    <div class="bg-dark bg-opacity-75 border border-secondary rounded-3 p-3 d-flex flex-column gap-4"
                        style="width:210px;">

                        <div class="d-flex align-items-center gap-4">
                            <i class="fa-regular fa-user fs-high-title text-primary"></i>
                            <div class="d-flex flex-column">
                                <span class="fw-bold fs-mid-title">25+</span>
                                <span class="text-secondary">Years Experience</span>
                            </div>

                        </div>

                        <hr class="bg-secondary m-0">

                        <div class="d-flex align-items-center gap-4">
                            <i class="fa-solid fa-building fs-high-title text-primary"></i>
                            <div class="d-flex flex-column">
                                <span class="fw-bold fs-mid-title">850+</span>
                                <span class="text-secondary">Projects Completed</span>
                            </div>
                        </div>

                        <hr class="bg-secondary m-0">

                        <div class="d-flex align-items-center gap-4">
                            <i class="fa-regular fa-face-smile fs-high-title text-primary"></i>
                            <div class="d-flex flex-column">
                                <span class="fw-bold fs-mid-title">98%</span>
                                <span class="text-secondary">Client Satisfaction</span>
                            </div>
                        </div>

                    </div>

                </div>

            </div> 
        </div>

        <div class="d-flex align-items-center position-relative bg-dark bg-opacity-50 py-10">
            <div class="wrapper1 d-flex justify-content-between align-items-center w-100 text-secondary w-100 gap-20 px-20 position-absolute">
                <img src="../../assets/media/images/en/demo2/brand1.png" class="w-10" alt="">
                <img src="../../assets/media/images/en/demo2/brand2.png" class="w-10" alt="">
                <img src="../../assets/media/images/en/demo2/brand3.png" class="w-10" alt="">
                <img src="../../assets/media/images/en/demo2/brand4.png" class="w-10" alt="">
                <img src="../../assets/media/images/en/demo2/brand5.png" class="w-10" alt="">
                <img src="../../assets/media/images/en/demo2/brand6.png" class="w-10" alt="">  
            </div>
            <div class="wrapper2 d-flex justify-content-between align-items-center w-100 text-secondary w-100 gap-20 px-20 position-absolute">
                <img src="../../assets/media/images/en/demo2/brand1.png" class="w-10" alt="">
                <img src="../../assets/media/images/en/demo2/brand2.png" class="w-10" alt="">
                <img src="../../assets/media/images/en/demo2/brand3.png" class="w-10" alt="">
                <img src="../../assets/media/images/en/demo2/brand4.png" class="w-10" alt="">
                <img src="../../assets/media/images/en/demo2/brand5.png" class="w-10" alt="">
                <img src="../../assets/media/images/en/demo2/brand6.png" class="w-10" alt="">  
            </div>
        </div>

    </section>

    <section class="we-do bg-specific">
        <div class="container d-flex gap-6 w-100 flex-column flex-xxl-row ">

            <div class="d-flex flex-column gap-4 col-10 col-xxl-3 align-items-start">
                <span class="text-primary text-uppercase fw-bold fs-big d-block">
                    What We Do
                </span>

                <h2 class="fw-bold">
                    Smart Construction 
                    Lasting Impressions
                </h2>

                <div style="width:60px;height:4px;" class="bg-primary rounded-4"></div>

                <p class="text-secondary text-text">
                    From concept to completion, we provide end-to-end
                    construction services tailored to your needs with
                    unmatched quality and reliability.
                </p>

                <a href="#" class="bg-dark px-4 py-2 rounded-1 fw-semibold d-flex align-items-center gap-4 text-light d-flex justify-content-center fs-big">
                    ALL SERVICES
                    <i class="fa-solid fa-arrow-right text-primary"></i>
                </a>
            </div>

            <div class="d-flex gap-4 gap-lg-2 flex-column flex-xxl-row flex-xl-row flex-lg-row">
                <%- include('../components/core-services-secondary-card/content.ejs', {coreServicesSecondaryCard: t.components.coreServicesSecondaryCard}); -%>
                <%- include('../components/core-services-secondary-card/content.ejs', {coreServicesSecondaryCard: t.components.coreServicesSecondaryCard}); -%>
                <%- include('../components/core-services-secondary-card/content.ejs', {coreServicesSecondaryCard: t.components.coreServicesSecondaryCard}); -%>
                <%- include('../components/core-services-secondary-card/content.ejs', {coreServicesSecondaryCard: t.components.coreServicesSecondaryCard}); -%>
            </div>
        </div>
    </section>

    <section class="about py-0 bg-dark">
            <div class="row ps-20">

                <div class="col-lg-5 text-secondary py-8">
                    <div class="d-flex flex-column gap-3 align-items-start">

                        <span class="text-uppercase text-secondary fs-big">About Our Company</span>

                        <h2 class="fw-bold ">
                            Building with Purpose.
                            Delivering Excellence
                        </h2>
                        <div style="width:60px;height:4px;" class="bg-primary rounded-4"></div>

                        <p class="text-text">
                            With over 25 years of experience, Construct has become a
                            trusted name in the construction industry. We are committed
                            to building structures that stand the test of time.
                        </p>

                        <div class="row g-4 my-1">

                            <div class="col-6 col-md-3 text-center d-flex flex-column gap-3 border-end ">
                                <i class="fa-solid fa-shield-halved text-primary"></i>
                                <p class="fw-semibold fs-big px-3">
                                    Quality
                                    Craftsmanship
                                </p>
                            </div>

                            <div class="col-6 col-md-3 text-center d-flex flex-column gap-3 border-end ">
                                <i class="fa-solid fa-seedling text-primary"></i>
                                <p class="fw-semibold fs-big px-3">
                                    Sustainable
                                    Practices
                                </p>
                            </div>

                            <div class="col-6 col-md-3 text-center d-flex flex-column gap-3 border-end ">
                                <i class="fa-solid fa-helmet-safety text-primary"></i>
                                <p class="fw-semibold fs-big px-3">
                                    Skilled
                                    Professionals
                                </p>
                            </div>

                            <div class="col-6 col-md-3 text-center d-flex flex-column gap-3 ">
                                <i class="fa-regular fa-clock text-primary"></i>
                                <p class="fw-semibold fs-big px-3">
                                    On-Time
                                    Delivery
                                </p>
                            </div>

                        </div>

                        <a href="#" class="mt-2 service px-4 py-2 fw-semibold rounded-1 bg-primary text-dark fs-big d-flex justify-content-center align-items-center gap-2 border-primary border">
                            MORE ABOUT US
                            <i class="fa-solid fa-arrow-right"></i>
                        </a>

                    </div>
                </div>

                <div class="d-flex flex-column col-lg-7">

                    <img src="../../assets/media/images/en/demo2/ChatGPT6.png" alt="Building" class="img-fluid h-100 ">


                </div>

            </div>
    </section>


    <section class="projects py-8">
        <div class="container d-flex flex-column gap-4">
            <div class="d-flex flex-column gap-4 col-10">
                <span class="text-uppercase fw-semibold fs-subtitle">PUR PROJECTS</span>

                <h2 class="fw-bold">Featured Projects</h2>

                <div style="width:60px;height:4px;" class="bg-primary rounded-4"></div>
            </div>
            <div class="d-flex flex-wrap">
                <div class="col-12 col-xxl-3 col-xl-3 col-lg-6 col-md-6 p-2">
                    <%- include('../components/secondary-project-card2/content.ejs', {projectCard: t.components.projectCard}); -%>
                </div>
                <div class="col-12 col-xxl-3 col-xl-3 col-lg-6 col-md-6 p-2">
                    <%- include('../components/secondary-project-card2/content.ejs', {projectCard: t.components.projectCard}); -%>
                </div>
                <div class="col-12 col-xxl-3 col-xl-3 col-lg-6 col-md-6 p-2">
                    <%- include('../components/secondary-project-card2/content.ejs', {projectCard: t.components.projectCard}); -%>
                </div>
                <div class="col-12 col-xxl-3 col-xl-3 col-lg-6 col-md-6 p-2">
                    <%- include('../components/secondary-project-card2/content.ejs', {projectCard: t.components.projectCard}); -%>
                </div>
                
            </div>
        </div>
    </section>

    <section class="values bg-dark">
        <div class="container ">
            <div class=" d-flex gap-10 flex-column flex-xxl-row flex-xl-row ">

                <div class="d-flex flex-column gap-4 col-12 col-xxl-4 col-xl-4">
                    <span class="text-uppercase fs-big fw-semibold text-text">Why Choose Us</span>

                    <h2 class="fw-bold text-secondary">
                        We Build More Than 
                        Structures
                    </h2>

                    <div style="width:60px;height:4px;" class="bg-primary rounded-4"></div>
                    <p class="fs-title text-light text-text">
                        We build trust, relationships,
                        and long-lasting solutions.
                    </p>
                </div>

                <div class="col-12 col-xxl-8 col-xl-8">
                    <%- include('../components/team-feature/content.ejs' , {teamFeature: t.components.teamFeature}); -%>
                </div>

            </div>
    </section>

    <section class="comments py-8 bg-specific">
        <div class="container d-flex gap-10 w-100 flex-column flex-xxl-row flex-xl-row flex-lg-row">
            <div class="d-flex flex-column gap-4 col-10 col-xxl-3 col-xl-4 col-lg-4">
                <span class="text-uppercase fw-semibold fs-subtitle">Testimonials</span>

                <h2 class="fw-bold">What Our Clients Say</h2>

                <div style="width:60px;height:4px;" class="bg-primary rounded-4"></div>

            </div>
            <div class="d-flex gap-4 gap-lg-2 flex-column flex-xxl-row flex-xl-row flex-lg-row">
                <%- include('../components/comment/content.ejs'); -%>
                <%- include('../components/comment/content.ejs'); -%>
                <%- include('../components/comment/content.ejs'); -%>
            </div>
        </div>
    </section>


    <section class="fast-contact py-4 d-flex bg-primary align-items-center justify-content-center">
        <div class="container d-flex justify-content-between flex-column flex-xxl-row flex-xl-row flex-lg-row flex-md-row gap-4 align-items-center">

            <div class="d-flex align-items-center gap-6">

                <i class="fa-solid fa-headset fs-high-title"></i>

                <div class="vr"></div>

                <div class="d-flex flex-column">
                    <h4 class="fw-bold fs-mid-title">Have a project in mind?</h4>

                    <span class="fw-bold fs-title">Let's build something great together!</span>
                </div>

            </div>

            <a href="#" class="px-6 py-3 fw-semibold text-uppercase fs-big bg-dark rounded text-secondary d-flex justify-content-center align-items-center gap-4">
                Get A Free Quote
                <i class="fa-solid fa-arrow-right text-primary"></i>
            </a>


        </div>
    </section>

    </main>

    <%- include('../components/footer/content.ejs', {accountFeatures: t.components.accountFeatures}); -%>

    <script src="./assets/js/mizchin.min.js"></script>
</body>

</html>