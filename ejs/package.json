{
    "name":"make-stracture-bootstrap",
    "version":"1.0.0",
    "description":"null",
    "type": "module",
    "scripts":{
        "watch": "concurrently \"sass --watch --update --style=expanded miz/_index.scss:assets/css/miz.min.css\" \"node miz/pkg/miz-controller.js --watch\" \"sass --watch --update --style=expanded sass/style.scss:assets/css/style.min.css\" \"sass --watch --update --style=expanded app/components/_index.scss:assets/css/components.min.css\"",
        "build": "concurrently \"sass --no-source-map --style=compressed miz/_index.scss:assets/css/miz.min.css\" \"node miz/pkg/miz-controller.js --build\" \"sass --no-source-map --style=compressed sass/style.scss:assets/css/style.min.css\" \"sass --no-source-map --style=compressed app/components/_index.scss:assets/css/components.min.css\"",
        "clean": "sass --no-source-map --style=expanded miz/_index.scss:assets/css/miz-clean.css && node miz/pkg/miz-min.cjs",
        "dev": "node miz/pkg/server.js",
        "build-bootstrap": "concurrently \"sass --no-source-map --style=expanded assets/vendors/bootstrap/scss/bootstrap.scss:assets/vendors/bootstrap/dist/css/bootstrap.css\" \"sass --no-source-map --style=compressed assets/vendors/bootstrap/scss/bootstrap.scss:assets/vendors/bootstrap/dist/css/bootstrap.min.css\""
    
    },
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "concurrently": "^9.0.0",
        "sass": "^1.77.8",
        "terser": "^5.28.1"
    },
    "dependencies": {
        "cheerio": "^1.1.2",
        "ejs": "^5.0.1",
        "express": "^5.1.0",
        "multer": "^2.0.2",
        "ncp": "^2.0.0"
    }
}